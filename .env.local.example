NEXT_PUBLIC_WC_PROJECT_ID=your_walletconnect_project_id
SESSION_SECRET=change-me-to-at-least-32-characters-long
NEXT_PUBLIC_DOMAIN=

# RPC endpoints — this app uses two separate connections:
#
# ETH_RPC_URL (server-side, secret)
#   Used by the SIWE library to verify signatures and resolve ENS names on the backend.
#   Never exposed to the browser.
#
# NEXT_PUBLIC_*_RPC_URL (client-side, public)
#   Used by wagmi in the browser for wallet interactions (balances, transactions, gas).
#   Must be NEXT_PUBLIC_* prefixed so Next.js bundles them into the client JS.
#   When unset, wagmi falls back to the chain's default public RPC (rate-limited).
#
# They can point to the same provider (e.g. Alchemy) but are separate because
# server keys should stay secret — higher rate limits, no risk of browser exposure.
ETH_RPC_URL=https://eth.llamarpc.com
NEXT_PUBLIC_MAINNET_RPC_URL=
NEXT_PUBLIC_SEPOLIA_RPC_URL=
